# MongoDB
MONGODB_URI=mongodb://localhost:27017/medryon

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Dev-only: skip email OTP verification during first-run setup.
# (so admin can be created without configuring SMTP first).
# Remove both lines once SMTP is configured via /doctor/settings.
SKIP_EMAIL_VERIFY=1
NEXT_PUBLIC_SKIP_EMAIL_VERIFY=1
